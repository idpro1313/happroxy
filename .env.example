# Persistent data on host (survives container recreate/update)
DATA_DIR=/opt/happdata

# --- Set interactively by scripts/install.sh on first run ---
# Public IP of the VM (required for subscription links and DNS checks)
SERVER_IP=

# Public HTTPS domain (optional at install; subdomain recommended, e.g. vpn.example.com)
PANEL_DOMAIN=
USE_HTTPS=true

# Traefik integration (Docker provider — see docker-compose.traefik.yml)
TRAEFIK_NETWORK=web
TRAEFIK_CERT_RESOLVER=le
# Path to Traefik acme.json on THIS host (set during setup-https if needed)
TRAEFIK_ACME_FILE=
# LE_CERT_DIR=/etc/letsencrypt/live/<PANEL_DOMAIN>   # certbot only
# TRAEFIK_UPSTREAM_HOST=172.17.0.1                     # file-provider fallback
# CERTBOT_WEBROOT=/var/www/certbot

# 3X-UI panel port (avoid 2053 default; 38471 is free on typical setups)
PANEL_PORT=38471

# 3X-UI subscription service port (internal; exposed for Happ clients)
SUB_PORT=2096

# Proxy inbound ports — must not conflict with Traefik/Portainer/wg-dashboard
HY2_PORT=4443
SS_PORT=8388
VMESS_PORT=16888
TROJAN_PORT=8443

# Optional: enable Trojan inbound port mapping in docker-compose (8443)
ENABLE_TROJAN=false

# Subscription settings (configure matching values in 3X-UI panel)
SUB_PATH=/sub/family
SUB_PROFILE_TITLE="Семейный VPN"
SUB_UPDATE_INTERVAL=6

# Generated by install.sh — do not commit .env
# XUI_ADMIN_USER=
# XUI_ADMIN_PASSWORD=
