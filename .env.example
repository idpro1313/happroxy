# Persistent data on host (survives container recreate/update)
DATA_DIR=/opt/happdata

# Public IP of the Ubuntu VM (required for subscription links and DNS checks)
SERVER_IP=

# Public HTTPS domain (recommended: subdomain, e.g. vpn.idpro13.ru)
# Panel and subscription URLs become https://PANEL_DOMAIN/... via Traefik on 443
PANEL_DOMAIN=
USE_HTTPS=true

# Optional overrides (usually auto-derived from PANEL_DOMAIN)
# SUB_PUBLIC_BASE=https://vpn.idpro13.ru/sub/family/
# LE_CERT_DIR=/etc/letsencrypt/live/vpn.idpro13.ru
# TRAEFIK_UPSTREAM_HOST=172.17.0.1
# CERTBOT_WEBROOT=/var/www/certbot

# 3X-UI panel port (avoid 2053 default; 38471 is free on typical setups)
PANEL_PORT=38471

# 3X-UI subscription service port (internal; exposed for Happ clients)
SUB_PORT=2096

# Proxy inbound ports — must not conflict with Traefik/Portainer/wg-dashboard
# Occupied on this VM: 80, 443, 8080, 8000, 9443, 10086, 17998
HY2_PORT=4443
SS_PORT=8388
VMESS_PORT=16888
TROJAN_PORT=8443

# Optional: enable Trojan inbound port mapping (set to false to skip publishing 8443)
ENABLE_TROJAN=false

# Subscription settings (configure matching values in 3X-UI panel)
SUB_PATH=/sub/family
SUB_PROFILE_TITLE="Семейный VPN"
SUB_UPDATE_INTERVAL=6

# Generated by install.sh — do not commit .env
# XUI_ADMIN_USER=
# XUI_ADMIN_PASSWORD=
